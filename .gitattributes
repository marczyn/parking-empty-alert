# Normalize line endings so shell scripts, configs and the .env template are always
# checked out with LF — a CRLF .env would otherwise corrupt values read by setup.sh
# (its load_env reader and the broker/secret consumers expect clean LF lines).
* text=auto eol=lf

# Explicitly LF for the files most likely to be edited on Windows + consumed by bash/Docker.
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf
*.hcl       text eol=lf
.env        text eol=lf
.env.example text eol=lf
Dockerfile* text eol=lf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.ova binary
*.qcow2 binary
