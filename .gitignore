# Secrets — NEVER commit real values to git!
.env
config/mosquitto/passwd
config/passwd

# Note: config/homeassistant/secrets.yaml is tracked in git as a TEMPLATE
# with placeholder values. setup.sh overwrites it locally with real secrets.
# After running setup.sh, do NOT git commit the local secrets.yaml — verify
# placeholder values are restored before any commit:
#   grep -E '(zmien_to|change_this|1234567)' config/homeassistant/secrets.yaml

# HA runtime files
config/homeassistant/.storage/
config/homeassistant/.cloud/
config/homeassistant/home-assistant_v2.db*
config/homeassistant/home-assistant.log*
config/homeassistant/blueprints/
config/homeassistant/deps/
config/homeassistant/tts/
config/homeassistant/www/
config/homeassistant/custom_components/

# Frigate runtime
config/frigate/clips/
config/frigate/recordings/
config/frigate/model_cache/
config/frigate/.vector.db*

# Docker volumes (managed by Docker, not git)
.docker-data/

# OS
.DS_Store
Thumbs.db
*.swp
*.bak

# Editor
.vscode/
.idea/
