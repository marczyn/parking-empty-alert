###############################################################################
# Skonfiguruj — skopiuj ten plik jako ".env" i wpisz swoje wartości:
#   cp .env.example .env
#   nano .env
# (lub po prostu uruchom bash scripts/setup.sh — pyta o wszystko interaktywnie)
###############################################################################

# ─── Reolink kamera ───
CAMERA_IP=192.168.1.100
RTSP_USER=frigate
RTSP_PASSWORD=zmien_to_haslo

# ─── MQTT (wewnętrzne, dowolne hasło) ───
MQTT_USER=frigate
MQTT_PASSWORD=zmien_to_haslo_tez

# ─── WhatsApp via CallMeBot ───
# Numer odbierającego (Twój), format międzynarodowy BEZ "+":
#   PL przykład: 48501234567
WHATSAPP_PHONE=48501234567
# APIKEY z CallMeBot (po wysłaniu na WhatsApp do +34 644 11 11 11
# wiadomości "I allow callmebot to send me messages"):
WHATSAPP_APIKEY=1234567
