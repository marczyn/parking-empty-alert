###############################################################################
# Configuration — copy this file as ".env" and fill in your values:
#   cp .env.example .env
#   nano .env
# (or just run bash scripts/setup.sh — it asks for everything interactively)
###############################################################################

# ─── Reolink camera ───
CAMERA_IP=192.168.1.100
RTSP_USER=frigate
RTSP_PASSWORD=change_this_password

# ─── MQTT (internal, any password) ───
MQTT_USER=frigate
MQTT_PASSWORD=change_this_password_too

# ─── WhatsApp via CallMeBot ───
# Receiver phone number (yours), international format WITHOUT "+":
#   PL example: 48501234567
WHATSAPP_PHONE=48501234567
# APIKEY from CallMeBot (after sending on WhatsApp to +34 644 11 11 11
# the message "I allow callmebot to send me messages"):
WHATSAPP_APIKEY=1234567

# ─── Timezone (IANA name) ───
# Examples: Europe/Warsaw, America/New_York, Asia/Tokyo, UTC
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
