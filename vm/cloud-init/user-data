#cloud-config
# Build-time cloud-init — only used during Packer image construction.
# Sets a temporary password so Packer can SSH in, enables sudo, grows disk.
# This file is NOT present in the final VM image.

users:
  - name: debian
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    shell: /bin/bash

ssh_pwauth: true

chpasswd:
  expire: false
  list: |
    debian:packer-build

# Auto-grow partition to full disk size
growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

# Ensure apt is fresh
package_update: true
package_upgrade: false

packages:
  - qemu-guest-agent
  - cloud-guest-utils
